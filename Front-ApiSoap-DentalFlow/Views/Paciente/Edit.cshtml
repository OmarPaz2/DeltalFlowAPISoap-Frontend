@model Front_ApiSoap_DentalFlow.Models.PacienteResponse

@{
    
    ViewData["Title"] = "Editar Paciente";
}

<h1>Edición de Pacientes</h1>

<div class="container mt-4">
    @if (ViewBag.MensajeError != null)
    {
        <div class="alert alert-danger bg-danger bg-opacity-10 text-danger border-0 p-3 rounded-4 mb-3 d-flex align-items-center shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
            <div>
                <span class="fw-bold">Error:</span> @ViewBag.MensajeError
            </div>
        </div>
    }

    <!-- Contenedor del formulario con tu color de fondo -->
    <div class="bg-info bg-opacity-25 p-4 rounded-4 shadow-sm">
        <h2 class="mb-4 text-dark text-center fw-bold">Modificar Datos del Paciente</h2>

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            @* Campo oculto muy importante para conservar el ID al guardar *@
            <input type="hidden" asp-for="id" />

            <div class="row g-3">
                <!-- DNI -->
                <div class="col-md-6">
                    <label asp-for="dni" class="form-label fw-semibold">DNI</label>
                    <input asp-for="dni" class="form-control rounded-3" placeholder="Ingrese el DNI" required />
                    <span asp-validation-for="dni" class="text-danger small"></span>
                </div>

                <!-- Nombre -->
                <div class="col-md-6">
                    <label asp-for="firstName" class="form-label fw-semibold">Nombre</label>
                    <input asp-for="firstName" class="form-control rounded-3" placeholder="Ingrese el nombre" required />
                    <span asp-validation-for="firstName" class="text-danger small"></span>
                </div>

                <!-- Apellido -->
                <div class="col-md-6">
                    <label asp-for="lastName" class="form-label fw-semibold">Apellido</label>
                    <input asp-for="lastName" class="form-control rounded-3" placeholder="Ingrese el apellido" required />
                    <span asp-validation-for="lastName" class="text-danger small"></span>
                </div>

                <!-- Fecha de Nacimiento (El type="date" jala automáticamente tu DateOnly) -->
                <div class="col-md-6">
                    <label asp-for="birthDate" class="form-label fw-semibold">Fecha de Nacimiento</label>
                    <input asp-for="birthDate" type="date" class="form-control rounded-3" required />
                    <span asp-validation-for="birthDate" class="text-danger small"></span>
                </div>

                <!-- Género (Se marcará la opción correcta automáticamente según el modelo) -->
                <div class="col-md-6">
                    <label asp-for="gender" class="form-label fw-semibold">Género</label>
                    <select asp-for="gender" class="form-select rounded-3" required>
                        <option value="">Seleccione...</option>
                        <option value="M">Masculino</option>
                        <option value="F">Femenino</option>
                        <option value="Otro">Otro</option>
                    </select>
                    <span asp-validation-for="gender" class="text-danger small"></span>
                </div>

                <!-- Teléfono -->
                <div class="col-md-6">
                    <label asp-for="phone" class="form-label fw-semibold">Teléfono</label>
                    <input asp-for="phone" type="tel" class="form-control rounded-3" placeholder="Ej: +51 999999999" />
                    <span asp-validation-for="phone" class="text-danger small"></span>
                </div>

                <!-- Correo Electrónico -->
                <div class="col-md-6">
                    <label asp-for="email" class="form-label fw-semibold">Correo Electrónico</label>
                    <input asp-for="email" type="email" class="form-control rounded-3" placeholder="ejemplo@correo.com" />
                    <span asp-validation-for="email" class="text-danger small"></span>
                </div>

                <!-- Dirección -->
                <div class="col-md-6">
                    <label asp-for="address" class="form-label fw-semibold">Dirección</label>
                    <input asp-for="address" class="form-control rounded-3" placeholder="Dirección completa" />
                    <span asp-validation-for="address" class="text-danger small"></span>
                </div>
            </div>

            <!-- Botones de Acción -->
            <div class="mt-4 d-flex gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-4 fw-bold">Cancelar</a>
                <button type="submit" class="btn bg-info bg-opacity-50 text-dark fw-bold px-4 py-2 rounded-4 border-0 shadow-sm">
                    Actualizar Datos
                </button>
            </div>
        </form>
    </div>
</div>

@* --- MODAL DE ÉXITO DE EDICIÓN --- *@
@if (Model != null && ViewBag.EditExitoso == true)
{
    <div class="modal fade" id="modalResultado" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-4 rounded-4 border-0 shadow-lg" style="background-color: white">

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-dark">¡Paciente Actualizado con Éxito!</h5>
                </div>

                <div class="modal-body text-dark">
                    <p class="mb-3">Se han modificado correctamente los datos en la base de datos:</p>

                    <ul class="list-group list-group-flush rounded-3 overflow-hidden">
                        <li class="list-group-item bg-transparent border-bottom border-dark border-opacity-10"><strong><span class="fw-bold" style="color: #002d62 !important;">ID:</span></strong> @Model.id</li>
                        <li class="list-group-item bg-transparent border-bottom border-dark border-opacity-10"><strong><span class="fw-bold" style="color: #002d62 !important;">DNI:</span></strong> @Model.dni</li>
                        <li class="list-group-item bg-transparent border-bottom border-dark border-opacity-10"><strong><span class="fw-bold" style="color: #002d62 !important;">Nombre:</span></strong> @Model.firstName @Model.lastName</li>
                        <li class="list-group-item bg-transparent border-bottom border-dark border-opacity-10"><strong><span class="fw-bold" style="color: #002d62 !important;">Email:</span></strong> @Model.email</li>
                        <li class="list-group-item bg-transparent border-bottom border-dark border-opacity-10"><strong><span class="fw-bold" style="color: #002d62 !important;">Teléfono:</span></strong> @Model.phone</li>
                        <li class="list-group-item bg-transparent border-0"><strong><span class="fw-bold" style="color: #002d62 !important;">Dirección:</span></strong> @Model.address</li>
                    </ul>
                </div>

                <div class="modal-footer border-0 justify-content-center gap-2 pt-3">
                    <!-- Botón OK: Regresa al Listado General Index -->
                    <a asp-action="Index" class="btn bg-info bg-opacity-50 p-3 rounded-4 fw-bold text-decoration-none text-dark flex-grow-1 text-center">
                        Regresar al Listado
                    </a>

                    <!-- Botón Crear Cita: Envía el ID a la vista de citas directamente -->
                    <a asp-controller="Cita" asp-action="Crear" asp-route-pacienteDni="@Model.id" class="btn bg-info bg-opacity-50 p-3 rounded-4 fw-bold text-decoration-none text-dark flex-grow-1 text-center">
                        Crear Cita
                    </a>
                </div>

            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var myModal = new bootstrap.Modal(document.getElementById('modalResultado'));
                myModal.show();
            });
        </script>
    }
}
