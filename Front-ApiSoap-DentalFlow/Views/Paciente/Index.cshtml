@model IEnumerable<Front_ApiSoap_DentalFlow.Models.PacienteResponse>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<div class="card mb-4 border-primaryShadow">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-search"></i> Criterios de Búsqueda de Pacientes</h5>
    </div>
    <div class="card-body">
        <form asp-controller="Paciente" asp-action="Buscar" method="get" id="searchForm" onsubmit="return validarCamposBusqueda()">
            <div class="row g-3">
                <!-- Input: Nombre -->
                <div class="col-md-3">
                    <label for="nombre" class="form-label fw-bold">Nombre</label>
                    <input type="text" id="nombre" name="nombre" class="form-control" placeholder="Ej: Juan" />
                </div>

                <!-- Input: Apellido -->
                <div class="col-md-3">
                    <label for="apellido" class="form-label fw-bold">Apellido</label>
                    <input type="text" id="apellido" name="apellido" class="form-control" placeholder="Ej: Pérez" />
                </div>

                <!-- Input: DNI -->
                <div class="col-md-3">
                    <label for="dni" class="form-label fw-bold">DNI</label>
                    <input type="text" id="dni" name="dni" class="form-control" placeholder="8 dígitos" maxlength="8" oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                </div>

                <!-- Botón de Acción -->
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100 fw-bold">
                        <i class="bi bi-search"></i> Buscar Paciente
                    </button>
                </div>
            </div>
            <!-- Alerta oculta para errores de validación -->
            <div id="validationAlert" class="alert alert-danger mt-3 d-none" role="alert">
                Debe completar al menos un campo para realizar la búsqueda.
            </div>
        </form>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.dni)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.firstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.lastName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.birthDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.gender)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.phone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.address)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.dni)
            </td>
            <td>
                @Html.DisplayFor(model => item.firstName)
            </td>
            <td>
                @Html.DisplayFor(model => item.lastName)
            </td>
            <td>
                @Html.DisplayFor(model => item.birthDate)
            </td>
            <td>
                @Html.DisplayFor(model => item.gender)
            </td>
            <td>
                @Html.DisplayFor(model => item.phone)
            </td>
            <td>
                @Html.DisplayFor(model => item.email)
            </td>
            <td>
                @Html.DisplayFor(model => item.address)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

@section Scripts {
    <script>
        function validarCamposBusqueda() {
            // Capturamos los valores recortando espacios en blanco
            const nombre = document.getElementById('nombre').value.trim();
            const apellido = document.getElementById('apellido').value.trim();
            const dni = document.getElementById('dni').value.trim();
            const alertBox = document.getElementById('validationAlert');

            // Evaluamos la condición: Si los 3 están vacíos, frena el envío
            if (nombre === "" && apellido === "" && dni === "") {
                alertBox.classList.remove('d-none'); // Muestra la alerta de Bootstrap
                return false; // Cancela el submit del formulario
            }

            alertBox.classList.add('d-none'); // Oculta la alerta si pasa la regla
            return true; // Permite enviar los datos al controlador
        }
    </script>
}
