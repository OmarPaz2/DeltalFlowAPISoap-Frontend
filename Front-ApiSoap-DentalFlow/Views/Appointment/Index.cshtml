@model IEnumerable<Front_ApiSoap_DentalFlow.Models.Appointment.AppointmentViewModel>

<div class="bg-info bg-opacity-50 p-4 rounded-4">

    <h2 class="text-center mb-4">
        Gestión de Citas
    </h2>

    <div class="mb-3">

        <a asp-action="Create"
           class="btn btn-info text-white">
            Nueva Cita
        </a>

        <a asp-controller="Dashboard"
           asp-action="Index"
           class="btn btn-info text-white">
            Dashboard
        </a>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="bg-white p-4 rounded-4 shadow-sm">

        <table class="table table-bordered table-hover">

            <thead class="table-info">

                <tr>
                    <th>ID</th>
                    <th>Paciente</th>
                    <th>Odontólogo</th>
                    <th>Tipo Cita</th>
                    <th>Monto</th>
                    <th>Motivo</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.Id</td>

                        <td>@item.NombrePaciente</td>

                        <td>@item.NombreOdontologo</td>

                        <td>@item.TipoCita</td>

                        <td>S/. @item.Monto</td>

                        <td>@item.Motivo</td>

                        <td>

                            @if (item.Estado == "CANCELLED")
                            {
                                <span class="badge bg-danger">
                                    Cancelada
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    Activa
                                </span>
                            }

                        </td>

                        <td>

                            @if (item.Estado != "CANCELLED")
                            {
                                <a asp-action="Cancel"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">
                                    Cancelar
                                </a>

                                <a asp-controller="Pago"
                                   asp-action="CreatePagoCita"
                                   class="btn btn-info btn-sm text-white">
                                    Pagar
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">
                                    Sin acciones
                                </span>
                            }

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>