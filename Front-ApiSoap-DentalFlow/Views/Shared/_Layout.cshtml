@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var isLogin =
        currentController == "Auth" &&
        currentAction == "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Front_ApiSoap_DentalFlow</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Front_ApiSoap_DentalFlow.styles.css" asp-append-version="true" />
</head>
<body>

    @if (!isLogin)
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">

                    <a class="navbar-brand"
                       asp-controller="Home"
                       asp-action="Index">
                        Front_ApiSoap_DentalFlow
                    </a>

                    <button class="navbar-toggler"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#navbarMain">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarMain">
                        <ul class="navbar-nav flex-grow-1">

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Usuario"
                                   asp-action="Index">
                                    Sesiones de Usuarios
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Dashboard"
                                   asp-action="Index">
                                    Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Paciente"
                                   asp-action="Index">
                                    Pacientes
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Material"
                                   asp-action="Index">
                                    Materiales
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Appointment"
                                   asp-action="Index">
                                    Citas
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Tratamiento"
                                   asp-action="Index">
                                    Tratamientos
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Pago"
                                   asp-action="Index">
                                    Pagos
                                </a>
                            </li>

                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }

    @if (isLogin)
    {
        <main role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    @if (!isLogin)
    {
        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - Front_ApiSoap_DentalFlow -
                <a asp-controller="Home" asp-action="Privacy">
                    Privacy
                </a>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>