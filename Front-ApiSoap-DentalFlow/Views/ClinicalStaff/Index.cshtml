@model IEnumerable<Front_ApiSoap_DentalFlow.Models.ClinicalStaffViewModel>

@{
    ViewData["Title"] = "Personal Clínico";
}

<h1>Personal Clínico</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger bg-danger bg-opacity-10 text-danger border-0 p-3 rounded-4 mb-3 d-flex align-items-center shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
        <div>
            <span class="fw-bold">Error:</span> @TempData["ErrorMessage"]
        </div>
    </div>
}

<div class="d-flex justify-content-end mb-3">
    <a asp-action="Perfil" class="btn bg-info bg-opacity-50 p-3 rounded-4 fw-bold text-dark text-decoration-none shadow-sm d-inline-flex align-items-center gap-2">
        <i class="bi bi-person-plus-fill fs-5"></i> Añadir nuevo Personal
    </a>
</div>

<div class="card mb-4 p-2 rounded-4 border-0 shadow-sm" style="background-color: #cff4fc !important;">
    <div class="card-header bg-transparent border-0 pb-0">
        <h5 class="mb-0 fw-bold" style="color: #002d62 !important;">
            <i class="bi bi-search"></i> Criterios de Búsqueda de Personal Clínico
        </h5>
    </div>
    <div class="card-body">
        <form asp-controller="ClinicalStaff" asp-action="Index" method="get" id="searchForm" onsubmit="return validarCamposBusqueda()">
            <div class="row g-3">
                <!-- Input: Apellido -->
                <div class="col-md-4">
                    <label for="apellido" class="form-label fw-bold text-dark">Apellido</label>
                    <input type="text" id="apellido" name="apellido" class="form-control rounded-3 border-0 shadow-sm" placeholder="Ej: Pérez" value="@Context.Request.Query["apellido"]" />
                </div>

                <!-- Select: Especialidad -->
                <div class="col-md-4">
                    <label for="idEspecialidad" class="form-label fw-bold text-dark">Especialidad</label>
                    <select id="idEspecialidad" name="idEspecialidad" class="form-select rounded-3 border-0 shadow-sm">
                        <option value="0">-- Seleccione Especialidad --</option>
                        @if (ViewBag.Especialidades != null)
                        {
                            foreach (var esp in (List<Front_ApiSoap_DentalFlow.Models.Specialty.SpecialtyVM>)ViewBag.Especialidades)
                            {
                                <! -- Mantiene seleccionada la opción buscada -->
                                if (Context.Request.Query["idEspecialidad"] == esp.id.ToString())
                                {
                                    <option value="@esp.id" selected="selected">@esp.name</option>
                                }
                                else
                                {
                                    <option value="@esp.id">@esp.name</option>
                                }
                            }
                        }
                    </select>
                </div>

                <!-- Botón de Acción -->
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn bg-info bg-opacity-50 p-2 rounded-4 fw-bold text-dark w-100 border-0 shadow-sm">
                        <i class="bi bi-search"></i> Buscar Personal
                    </button>
                </div>
            </div>

            <!-- Alerta de Validación -->
            <div id="validationAlert" class="alert alert-danger bg-danger bg-opacity-10 text-danger border-0 p-3 rounded-4 mt-3 d-none shadow-sm" role="alert">
                <span class="fw-bold">Error:</span> Debe ingresar el apellido o seleccionar una especialidad para realizar la búsqueda.
            </div>
        </form>
    </div>
</div>

<div class="table-responsive rounded-4 shadow-sm bg-white p-3">
    <table class="table table-hover align-middle mb-0">
        <thead class="border-bottom border-dark border-opacity-10">
            <tr class="text-dark">
                <th class="fw-bold" style="color: #002d62 !important;">NRO. LICENCIA</th>
                <th class="fw-bold">NOMBRES</th>
                <th class="fw-bold">APELLIDOS</th>
                <th class="fw-bold">ESPECIALIDAD</th>
                <th class="fw-bold">TELÉFONO</th>
                <th class="fw-bold text-center">ESTADO</th>
                <th class="text-center fw-bold">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">No se encontraron resultados. Realice una búsqueda con al menos un criterio.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr class="border-bottom border-light">
                    <td class="fw-bold" style="color: #002d62 !important;">
                        @Html.DisplayFor(model => item.licenseNumber)
                    </td>
                    <td>@Html.DisplayFor(model => item.firstName)</td>
                    <td>@Html.DisplayFor(model => item.lastName)</td>
                    <td>@Html.DisplayFor(model => item.specialtyName)</td>
                    <td>@Html.DisplayFor(model => item.phone)</td>
                    <td class="text-center">
                        @if (item.disponible)
                        {
                            <span class="badge bg-success bg-opacity-10 text-success p-2 rounded-3">Disponible</span>
                        }
                        else
                        {
                            <span class="badge bg-danger bg-opacity-10 text-danger p-2 rounded-3">No Disponible</span>
                        }
                    </td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-1">
                            <a asp-action="Edit" asp-route-id="@item.id" class="btn bg-info bg-opacity-50 py-1 px-2 rounded-3 text-dark text-decoration-none btn-sm fw-bold small shadow-sm">
                                <i class="bi bi-pencil-square"></i> Editar
                            </a>                        
                            <a class="btn bg-danger bg-opacity-10 py-1 px-2 rounded-3 text-danger text-decoration-none btn-sm fw-bold small shadow-sm"
                               data-bs-toggle="modal"
                               data-bs-target="#modalEliminacionConfirmar"
                               onclick="verificarEliminacion('@item.licenseNumber', '@item.id')">
                                <i class="bi bi-trash"></i> Eliminar
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal de Bootstrap para confirmar eliminación -->
<div class="modal fade" id="modalEliminacionConfirmar" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-4 rounded-4 border-0 shadow-lg" style="background-color: white">

            <div class="modal-header border-0 pb-0 justify-content-center">
                <h5 class="modal-title fw-bold text-danger text-center">¿Confirmar Eliminación?</h5>
            </div>

            <div class="modal-body text-dark text-center fs-5 pt-3">
                <p class="mb-0">
                    Estás a punto de eliminar al personal con Licencia:
                    <strong id="licenciaPersonalEliminar" class="fw-bold" style="color: #002d62 !important;"></strong>
                </p>
            </div>

            <form asp-action="Delete" method="post" id="formEliminarPersonal">
                <input type="hidden" id="idPersonalEliminar" name="id" value="" />

                <div class="modal-footer border-0 justify-content-center gap-2 pt-4">
                    <button type="button" class="btn bg-secondary bg-opacity-20 p-3 rounded-4 fw-bold text-dark flex-grow-1 text-center border-0" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn bg-danger bg-opacity-70 p-3 rounded-4 fw-bold text-white flex-grow-1 text-center border-0">
                        Eliminar
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
       // Validación en el Frontend: Al menos un criterio es requerido
        function validarCamposBusqueda() {
            var apellido = document.getElementById("apellido").value.trim();
            var idEspecialidad = document.getElementById("idEspecialidad").value;
            var alertBox = document.getElementById("validationAlert");

            // Si el apellido está vacío Y TAMBIÉN la especialidad se quedó en "0" (no seleccionada)
            if (apellido === "" && idEspecialidad === "0") {
                alertBox.classList.remove("d-none");
                return false; 
            }

            alertBox.classList.add("d-none");
            return true;
        }

        // Configuración de datos dinámicos en el modal de eliminación
        function verificarEliminacion(licencia, id) {
            document.getElementById("licenciaPersonalEliminar").innerText = licencia;
            document.getElementById("idPersonalEliminar").value = id;
        }
    </script>
}
