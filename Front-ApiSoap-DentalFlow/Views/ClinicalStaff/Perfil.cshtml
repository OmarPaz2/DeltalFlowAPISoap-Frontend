@model Front_ApiSoap_DentalFlow.Models.ClinicalStaffRequest

@{
    ViewData["Title"] = "Completar Perfil";
}

<h1>Registro de Personal Clínico</h1>

<div class="container mt-4">
    <!-- Mensaje de Éxito -->
    @if (ViewBag.SuccessMessage != null)
    {
        <div class="alert alert-success bg-success bg-opacity-10 text-success border-0 p-3 rounded-4 mb-3 d-flex align-items-center shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <div>
                <span class="fw-bold">Éxito:</span> @ViewBag.SuccessMessage
            </div>
        </div>
    }

    <!-- Mensaje de Error -->
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger bg-danger bg-opacity-10 text-danger border-0 p-3 rounded-4 mb-3 d-flex align-items-center shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
            <div>
                <span class="fw-bold">Error:</span> @ViewBag.ErrorMessage
            </div>
        </div>
    }

    <div class="bg-info bg-opacity-25 p-4 rounded-4 shadow-sm">
        <h2 class="mb-4 text-dark text-center fw-bold">Completar Perfil Clínico</h2>

        <form asp-action="Perfil" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Campo Oculto para Usuario (ID) -->
            <input type="hidden" asp-for="usuario" />

            <div class="row g-3">
                <!-- Nro. de Licencia -->
                <div class="col-md-6">
                    <label asp-for="licenseNumber" class="form-label fw-semibold">Número de Licencia</label>
                    <input asp-for="licenseNumber" class="form-control rounded-3" placeholder="Ingrese el nro. de colegiatura" required />
                    <span asp-validation-for="licenseNumber" class="text-danger small"></span>
                </div>

                <!-- Especialidad (Select) -->
                <div class="col-md-6">
                    <label asp-for="specialty" class="form-label fw-semibold">Especialidad Médica</label>
                    <select asp-for="specialty" class="form-select rounded-3" required>
                        <option value="">Seleccione especialidad...</option>
                        @if (ViewBag.Especialidades != null)
                        {
                            foreach (var esp in (List<Front_ApiSoap_DentalFlow.Models.Specialty.SpecialtyVM>)ViewBag.Especialidades)
                            {
                                <option value="@esp.id">@esp.name</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="specialty" class="text-danger small"></span>
                </div>

                <!-- Nombre -->
                <div class="col-md-6">
                    <label asp-for="firstName" class="form-label fw-semibold">Nombre</label>
                    <input asp-for="firstName" class="form-control rounded-3" placeholder="Ingrese el nombre" required />
                    <span asp-validation-for="firstName" class="text-danger small"></span>
                </div>

                <!-- Apellido -->
                <div class="col-md-6">
                    <label asp-for="lastName" class="form-label fw-semibold">Apellido</label>
                    <input asp-for="lastName" class="form-control rounded-3" placeholder="Ingrese el apellido" required />
                    <span asp-validation-for="lastName" class="text-danger small"></span>
                </div>

                <!-- Teléfono -->
                <div class="col-md-6">
                    <label asp-for="phone" class="form-label fw-semibold">Teléfono de Contacto</label>
                    <input asp-for="phone" type="tel" class="form-control rounded-3" placeholder="Ej: 999999999" required />
                    <span asp-validation-for="phone" class="text-danger small"></span>
                </div>

               
               
            </div>

            <!-- Botones de Acción -->
            <div class="mt-4 d-flex gap-2 justify-content-end">
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary px-4 py-2 rounded-4">Cancelar</a>
                <button type="submit" class="btn bg-info bg-opacity-50 text-dark fw-bold px-4 py-2 rounded-4 border-0 shadow-sm">
                    Guardar Perfil
                </button>
            </div>
        </form>
    </div>
</div>
