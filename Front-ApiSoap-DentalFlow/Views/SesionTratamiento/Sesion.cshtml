@model IEnumerable<Front_ApiSoap_DentalFlow.Models.Tratamiento.SesionTratameintoVM>

@{
    ViewData["Title"] = "Sesiones de Tratamiento";
    int index = 0;
}

<h1>Sesiones de Tratamiento</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger bg-danger bg-opacity-10 text-danger border-0 p-3 rounded-4 mb-3 d-flex align-items-center shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
        <div><span class="fw-bold">Error:</span> @TempData["ErrorMessage"]</div>
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-info bg-info bg-opacity-25 border-0 p-3 rounded-4 mb-3 d-flex align-items-center shadow-sm" role="alert">
        <i class="bi bi-info-circle-fill me-2 fs-5" style="color: #002d62 !important;"></i>
        <div class="text-dark"><span class="fw-bold" style="color: #002d62 !important;">Éxito:</span> @TempData["Success"]</div>
    </div>
}

<div class="d-flex justify-content-end mb-4">
    <a asp-action="Create" class="btn bg-info bg-opacity-50 p-3 rounded-4 fw-bold text-dark border-0 shadow-sm d-inline-flex align-items-center gap-2 text-decoration-none">
        <i class="bi bi-plus-circle-fill fs-5"></i> Programar Nueva Sesión
    </a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (Model == null || !Model.Any())
    {
        <div class="col-12 text-center text-muted py-4">No se encontraron sesiones registradas.</div>
    }
    else
    {
        foreach (var item in Model)
        {
            string claseFondo = (index % 2 == 0)
                ? "bg-info bg-opacity-50 p-4 rounded-4 h-100 border-0 shadow-sm d-flex flex-column justify-content-between"
                : "bg-info bg-opacity-25 p-4 rounded-4 h-100 border-0 shadow-sm d-flex flex-column justify-content-between";
            index++;

            <div class="col">
                <div class="card @claseFondo">
                    <div class="card-body p-0 mb-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="text-muted small fw-bold" style="color: #002d62 !important; opacity: 0.7;">ID: @item.idSesion</div>

                            <span class="badge @(item.asistenciaPaciente ? "bg-success" : "bg-secondary") bg-opacity-25 text-dark rounded-pill px-2 py-1 small fw-bold">
                                <i class="bi @(item.asistenciaPaciente ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-secondary") me-1"></i>
                                @(item.asistenciaPaciente ? "Asistió" : "Pendiente")
                            </span>
                        </div>

                        <h4 class="card-title fw-bold text-dark mb-3">@item.nombrePaciente @item.apellidoPaciente</h4>

                        <div class="d-flex flex-column gap-2 small text-dark">
                            <div><i class="bi bi-card-text me-2"></i><strong>DNI:</strong> @item.dni</div>
                            <div><i class="bi bi-calendar-event me-2"></i><strong>Prog:</strong> @item.fechaProgramada.ToString("dd/MM/yyyy HH:mm")</div>
                            @if (item.fechaRealizada != DateTime.MinValue)
                            {
                                <div><i class="bi bi-calendar-check me-2"></i><strong>Cierre:</strong> @item.fechaRealizada.ToString("dd/MM/yyyy HH:mm")</div>
                            }
                            <div><i class="bi bi-cash-coin me-2"></i><strong>Costo Parcial:</strong> <span class="fw-bold text-success">S/ @item.costoParcial.ToString("F2")</span></div>
                            <div><i class="bi bi-activity me-2"></i><strong>Estado:</strong> @item.estado</div>
                        </div>

                        @if (!string.IsNullOrEmpty(item.observaciones))
                        {
                            <div class="mt-3 pt-2 border-top border-dark border-opacity-10 small text-muted">
                                <strong>Obs:</strong> <span class="fst-italic">"@item.observaciones"</span>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 pt-2 border-top border-dark border-opacity-10">
                        @if (User.IsInRole("Odontologo"))
                        {
                            <button onclick="abrirFormulario('@Url.Action("Edit", new { id = item.idSesion })', 'Finalizar Sesión Clínica')"
                                    class="btn bg-white py-2 px-3 rounded-3 text-dark btn-sm fw-bold shadow-sm flex-grow-1 text-center border-0">
                                <i class="bi bi-stop-circle text-danger me-1"></i> Finalizar Sesión
                            </button>
                        }
                        else
                        {
                            <button onclick="verificarAsistencia('@item.nombrePaciente @item.apellidoPaciente', '@item.idSesion')"
                                    class="btn bg-dark bg-opacity-10 py-2 px-3 rounded-3 text-dark btn-sm fw-bold shadow-sm flex-grow-1 text-center border-0">
                                <i class="bi bi-calendar-check-fill me-1"></i> Marcar Asistencia
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

<div class="modal fade" id="modalFormulario" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-4 rounded-4 border-0 shadow-lg" style="background-color: white">
            <div class="modal-header border-0 pb-2 justify-content-center">
                <h5 class="modal-title fw-bold text-dark text-center" id="modalFormularioTitulo">Formulario</h5>
            </div>
            <div class="modal-body pt-2" id="modalFormularioContenido">
                <div class="text-center py-3">
                    <div class="spinner-border text-info" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalAsistenciaConfirmar" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content p-4 rounded-4 border-0 shadow-lg" style="background-color: white">
            <div class="modal-header border-0 pb-0 justify-content-center">
                <h5 class="modal-title fw-bold text-primary text-center">¿Confirmar Asistencia?</h5>
            </div>
            <div class="modal-body text-dark text-center fs-5 pt-3">
                <p class="mb-0">¿Registrar la asistencia del paciente?<br /><strong id="nombrePacienteAsistencia" class="fw-bold" style="color: #002d62 !important;"></strong></p>
            </div>
            <form asp-action="MarcarAsistencia" method="post" id="formAsistencia">
                <input type="hidden" id="idSesionAsistencia" name="id" value="" />
                <div class="modal-footer border-0 justify-content-center gap-2 pt-4">
                    <button type="button" class="btn bg-secondary bg-opacity-20 p-3 rounded-4 fw-bold text-dark flex-grow-1 text-center border-0" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn bg-info bg-opacity-75 p-3 rounded-4 fw-bold text-dark flex-grow-1 text-center border-0">Confirmar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Función AJAX idéntica a tu ejemplo para inyectar tu PartialView del Edit
        function abrirFormulario(url, titulo) {
            document.getElementById('modalFormularioTitulo').innerText = titulo;
            document.getElementById('modalFormularioContenido').innerHTML = `
                <div class="text-center py-3"><div class="spinner-border text-info" role="status"></div></div>`;

            var modalElement = document.getElementById('modalFormulario');
            var myModal = bootstrap.Modal.getOrCreateInstance(modalElement);
            myModal.show();

            fetch(url)
                .then(response => response.text())
                .then(html => {
                    document.getElementById('modalFormularioContenido').innerHTML = html;
                })
                .catch(error => {
                    document.getElementById('modalFormularioContenido').innerHTML = `
                        <div class="alert alert-danger border-0 rounded-4">No se pudo cargar el formulario de cierre.</div>`;
                });
        }

        // Manejo del modal de asistencia
        function verificarAsistencia(paciente, idSesion) {
            document.getElementById('nombrePacienteAsistencia').textContent = paciente;
            document.getElementById('idSesionAsistencia').value = idSesion;

            var modalElement = document.getElementById('modalAsistenciaConfirmar');
            var myModal = bootstrap.Modal.getOrCreateInstance(modalElement);
            myModal.show();
        }
    </script>
}