@model Front_ApiSoap_DentalFlow.ViewModels.UsuarioViewModel

@{
    ViewData["Title"] = "Crear Usuario";
}

<div class="container mt-4">

    <h3 class="text-primary">Crear Usuario</h3>

    <form method="post">

        <div class="mb-3">
            <label class="form-label">Username</label>
            <input asp-for="Username" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Rol ID</label>
            <input asp-for="RolId" class="form-control" />
        </div>

        <button class="btn btn-success">Guardar</button>
        <a href="/Usuario/Index" class="btn btn-secondary">Cancelar</a>

    </form>
</div>